# --- Secrets & local env ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/
pip-wheel-metadata/

# Tests / types / linters ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
/htmlcov/
.coverage
.coverage.*
coverage.xml

# Virtual environments (any subdirectory) ---
.venv/
venv/
env/

# --- OS / IDE ---
.DS_Store
.idea/

# --- Benchmark ---
# Prepared corpora: raw FLAC + cached downloads + chunked API inputs (often large binaries).
benchmark/data/prepared/*/audio/
benchmark/data/prepared/*/cache/
# VAD probe JSON (can be large; regenerate from pipeline/benchmark tooling as needed).
benchmark/data/prepared/*/vad_baseline/
# Hypotheses are regenerated by the STT API; keep *.ref.txt for evaluation pairs.
benchmark/data/prepared/benchmark/hypotheses/
benchmark/.torch/

# Loose audio probes under benchmark/ (manual experiments).
benchmark/*.wav
benchmark/*.mp3

# Hugging Face / model caches sometimes land under cwd during evaluation.
benchmark/.hf_cache/

# --- Pipeline ---
pipeline/audio_files/*
!pipeline/audio_files/.gitkeep

# CocoIndex scratch (if generated alongside the repo)
.cocoindex/

# SQLite or other throwaway DBs next to tooling
*.db

# --- Shared / tooling ---
shared/animation/.venv/
shared/animation/media/
